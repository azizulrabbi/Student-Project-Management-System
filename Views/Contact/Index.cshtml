@{ ViewData["Title"] = "Contact Us"; }

<div class="mb-4">
    <h2 class="fw-bold mb-1"><i class="bi bi-telephone me-2 text-primary"></i>Contact Us</h2>
    <p class="text-muted">Get in touch with King's Own Institute — we're here to help.</p>
</div>

<div class="row g-4">
    <!-- Sydney Campus -->
    <div class="col-md-6">
        <div class="card border-0 shadow-sm h-100 border-top border-4 border-primary">
            <div class="card-body p-4">
                <div class="d-flex align-items-center gap-2 mb-3">
                    <div class="quick-action-icon" style="width:48px;height:48px;font-size:1.4rem">
                        <i class="bi bi-building"></i>
                    </div>
                    <div>
                        <h5 class="fw-bold mb-0">Sydney Campus &amp; Library</h5>
                        <small class="text-muted">(Wynyard Green)</small>
                    </div>
                </div>

                <ul class="list-unstyled mb-0">
                    <li class="d-flex align-items-start gap-2 mb-3">
                        <i class="bi bi-geo-alt-fill text-primary mt-1"></i>
                        <div>
                            <div>Levels 7–11, 11 York St, Sydney</div>
                            <div>NSW 2000</div>
                        </div>
                    </li>
                    <li class="d-flex align-items-center gap-2 mb-3">
                        <i class="bi bi-clock-fill text-primary"></i>
                        <div>
                            <div class="fw-medium">Mon to Fri</div>
                            <div class="text-muted">8:30am – 5:00pm</div>
                        </div>
                    </li>
                    <li class="d-flex align-items-center gap-2 mb-3">
                        <i class="bi bi-telephone-fill text-primary"></i>
                        <a href="tel:0292833583" class="text-decoration-none">(02) 9283 3583</a>
                    </li>
                    <li class="d-flex align-items-center gap-2 mb-3">
                        <i class="bi bi-envelope-fill text-primary"></i>
                        <a href="mailto:ask@koi.edu.au" class="text-decoration-none">ask@koi.edu.au</a>
                    </li>
                    <li class="d-flex align-items-center gap-2">
                        <i class="bi bi-headset text-primary"></i>
                        <a href="mailto:ITsupport@koi.edu.au" class="text-decoration-none">ITsupport@koi.edu.au</a>
                        <span class="badge bg-info">IT Support</span>
                    </li>
                </ul>
            </div>
        </div>
    </div>

    <!-- Newcastle Campus -->
    <div class="col-md-6">
        <div class="card border-0 shadow-sm h-100 border-top border-4 border-success">
            <div class="card-body p-4">
                <div class="d-flex align-items-center gap-2 mb-3">
                    <div class="quick-action-icon" style="background:#f36d38" style="width:48px;height:48px;font-size:1.4rem">

                <ul class="list-unstyled mb-0">
                    <li class="d-flex align-items-start gap-2 mb-3">
                        <i class="bi bi-geo-alt-fill text-success mt-1"></i>
                        <div>
                            <div>Ground Floor and Level 1</div>
                            <div>59 Darby Street, Cooks Hill NSW 2300</div>
                        </div>
                    </li>
                    <li class="d-flex align-items-center gap-2 mb-3">
                        <i class="bi bi-clock-fill text-success"></i>
                        <div>
                            <div class="fw-medium">Mon to Fri</div>
                            <div class="text-muted">8:30am – 5:00pm</div>
                        </div>
                    </li>
                    <li class="d-flex align-items-center gap-2 mb-3">
                        <i class="bi bi-telephone-fill text-success"></i>
                        <a href="tel:0240910500" class="text-decoration-none">(02) 4091 0500</a>
                    </li>
                    <li class="d-flex align-items-center gap-2 mb-3">
                        <i class="bi bi-envelope-fill text-success"></i>
                        <a href="mailto:ask@koi.edu.au" class="text-decoration-none">ask@koi.edu.au</a>
                    </li>
                    <li class="d-flex align-items-center gap-2">
                        <i class="bi bi-headset text-success"></i>
                        <a href="mailto:ITsupport@koi.edu.au" class="text-decoration-none">ITsupport@koi.edu.au</a>
                        <span class="badge bg-info">IT Support</span>
                    </li>
                </ul>
            </div>
        </div>
    </div>
</div>


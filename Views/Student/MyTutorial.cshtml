@model SPMS.Models.Tutorial?
@{
    ViewData["Title"] = "My Tutorial";

    var myGroup        = ViewBag.MyGroup as SPMS.Models.TutorialGroup;
    var myMembership   = ViewBag.MyMembership as SPMS.Models.TutorialGroupMember;
    bool isLeader      = myMembership?.IsLeader ?? false;
    var latestGroupReq = ViewBag.LatestGroupReq as SPMS.Models.TutorialGroupRequest;
    var latestProjReq  = ViewBag.LatestProjReq  as SPMS.Models.TutorialGroupProjectRequest;
    var peers          = ViewBag.TutorialPeers  as List<SPMS.Models.TutorialEnrollment> ?? new();
    var joinable       = ViewBag.JoinableGroups as List<SPMS.Models.TutorialGroup> ?? new();
    var projects       = ViewBag.AvailableProjects as List<SPMS.Models.Project> ?? new();
    int groupMin       = ViewBag.GroupMin ?? 3;
    int groupMax       = ViewBag.GroupMax ?? 5;

    Func<SPMS.Models.TutorialGroupStatus, string> StatusBadge = s => s switch {
        SPMS.Models.TutorialGroupStatus.Forming          => "bg-secondary",
        SPMS.Models.TutorialGroupStatus.Ready            => "bg-primary",
        SPMS.Models.TutorialGroupStatus.AwaitingApproval => "bg-warning text-dark",
        SPMS.Models.TutorialGroupStatus.Approved         => "bg-success",
        SPMS.Models.TutorialGroupStatus.Rejected         => "bg-danger",
        _                                                => "bg-secondary"
    };
}

<div class="mb-4"><h4 class="fw-bold mb-0">My Tutorial</h4></div>

@if (Model == null)
{
    <div class="card border-0 shadow-sm">
        <div class="card-body text-center py-5 text-muted">
            <i class="bi bi-journal-x display-4 opacity-25 d-block mb-3"></i>
            <p>You have not been enrolled in a tutorial yet. Please contact your admin.</p>
        </div>
    </div>
}
else
{
    var tutorial = Model!;

    <div class="row g-4">

        <!-- Tutorial Info -->
        <div class="col-12">
            <div class="card border-0 shadow-sm">
                <div class="card-header koi-card-header py-3">
                    <span class="fw-semibold"><i class="bi bi-journal-bookmark me-2"></i>@tutorial.Name</span>
                </div>
                <div class="card-body p-3 d-flex gap-4 flex-wrap">
                    <div>
                        <div class="small text-muted">Tutor</div>
                        <div class="fw-medium">@tutorial.Tutor?.FullName</div>
                        <div class="small text-muted"><i class="bi bi-envelope me-1"></i>@tutorial.Tutor?.Email</div>
                    </div>
                    @if (myGroup != null)
                    {
                        <div>
                            <div class="small text-muted">My Group</div>
                            <div class="fw-medium">@myGroup.Name</div>
                            <span class="badge @StatusBadge(myGroup.Status) mt-1">@myGroup.Status</span>
                        </div>
                    }
                    else
                    {
                        <div>
                            <div class="small text-muted">My Group</div>
                            <div class="text-muted small">Not in a group yet</div>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Main Content -->
        <div class="col-lg-8">

            <!-- ── STATE: No group yet ────────────────────────────────────────── -->
            @if (myGroup == null)
            {
                <!-- Create Group -->
                <div class="card border-0 shadow-sm mb-4">
                    <div class="card-header koi-card-header py-3"><i class="bi bi-plus-circle me-2"></i>Create a New Group</div>
                    <div class="card-body p-3">
                        <p class="small text-muted mb-3">Create a group and become the leader. Other students from your tutorial can join. You need @groupMin&ndash;@groupMax members to request tutor approval.</p>
                        <form method="post" action="/Student/CreateTutorialGroup" class="d-flex gap-2">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="tutorialId" value="@tutorial.Id" />
                            <input name="name" class="form-control" placeholder="e.g. Team Alpha" required />
                            <button class="btn btn-koi px-3"><i class="bi bi-plus-lg me-1"></i>Create</button>
                        </form>
                    </div>
                </div>

                <!-- Join Existing Group -->
                @if (joinable.Any())
                {
                    <div class="card border-0 shadow-sm">
                        <div class="card-header koi-card-header py-3"><i class="bi bi-people me-2"></i>Join an Existing Group</div>
                        <div class="card-body p-3">
                            @foreach (var g in joinable)
                            {
                                <div class="d-flex justify-content-between align-items-center border rounded p-3 mb-2">
                                    <div>
                                        <div class="fw-semibold small">@g.Name <span class="badge @StatusBadge(g.Status) ms-1">@g.Status</span></div>
                                        <div class="small text-muted">@g.Members.Count / @groupMax members</div>
                                        <div class="d-flex flex-wrap gap-1 mt-1">
                                            @foreach (var m in g.Members)
                                            {
                                                <span class="badge bg-light text-dark border" style="font-size:.7rem;">@m.Student?.FullName</span>
                                            }
                                        </div>
                                    </div>
                                    <form method="post" action="/Student/JoinTutorialGroup">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="tutorialGroupId" value="@g.Id" />
                                        <button class="btn btn-outline-primary btn-sm ms-2"><i class="bi bi-box-arrow-in-right me-1"></i>Join</button>
                                    </form>
                                </div>
                            }
                        </div>
                    </div>
                }
                else
                {
                    <div class="alert alert-light border small text-muted"><i class="bi bi-info-circle me-2"></i>No open groups yet — be the first to create one!</div>
                }
            }
            else
            {
                <!-- Group Members Card -->
                <div class="card border-0 shadow-sm mb-4">
                    <div class="card-header koi-card-header py-3 d-flex justify-content-between align-items-center">
                        <span><i class="bi bi-people me-2"></i>@myGroup.Name</span>
                        <span class="badge @StatusBadge(myGroup.Status)">@myGroup.Status</span>
                    </div>
                    <div class="card-body p-3">
                        <ul class="list-group list-group-flush mb-3">
                            @foreach (var m in myGroup!.Members ?? new List<SPMS.Models.TutorialGroupMember>())
                            {
                                <li class="list-group-item px-0 py-2 d-flex align-items-center gap-2">
                                    <div class="rounded-circle bg-secondary text-white d-flex align-items-center justify-content-center fw-bold flex-shrink-0" style="width:34px;height:34px;">@(m.Student?.FullName?.FirstOrDefault() ?? '?')</div>
                                    <div class="flex-grow-1">
                                        <div class="small fw-medium">
                                            @m.Student?.FullName
                                            @if (m.IsLeader) { <span class="badge bg-warning text-dark ms-1" style="font-size:.65rem;">Leader</span> }
                                        </div>
                                        <div style="font-size:.72rem" class="text-muted"><i class="bi bi-envelope me-1"></i>@m.Student?.Email</div>
                                        @if (m.Student?.StudentNumber != null)
                                        {
                                            <div style="font-size:.72rem" class="text-muted"><i class="bi bi-hash me-1"></i>@m.Student?.StudentNumber</div>
                                        }
                                    </div>
                                </li>
                            }
                        </ul>

                        <!-- Leave button (Forming / Ready / Rejected only) -->
                        @if (myGroup.Status == SPMS.Models.TutorialGroupStatus.Forming ||
                             myGroup.Status == SPMS.Models.TutorialGroupStatus.Ready   ||
                             myGroup.Status == SPMS.Models.TutorialGroupStatus.Rejected)
                        {
                            <form method="post" action="/Student/LeaveTutorialGroup" onsubmit="return confirm('Leave this group?')">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="tutorialGroupId" value="@myGroup.Id" />
                                <button class="btn btn-outline-danger btn-sm"><i class="bi bi-box-arrow-left me-1"></i>Leave Group</button>
                            </form>
                        }
                    </div>
                </div>

                <!-- ── Forming: need more members ── -->
                @if (myGroup.Status == SPMS.Models.TutorialGroupStatus.Forming)
                {
                    <div class="alert alert-info border-0">
                        <i class="bi bi-info-circle me-2"></i>
                        Your group has <strong>@myGroup.Members.Count</strong> member(s). You need at least <strong>@groupMin</strong> to request tutor approval.
                        Share your group name with other enrolled students so they can join.
                    </div>
                }

                <!-- ── Ready: can request approval ── -->
                @if (myGroup.Status == SPMS.Models.TutorialGroupStatus.Ready && isLeader)
                {
                    <div class="card border-0 shadow-sm mb-4">
                        <div class="card-header koi-card-header py-3"><i class="bi bi-send me-2"></i>Request Tutor Approval</div>
                        <div class="card-body p-3">
                            <p class="small text-muted mb-2">Your group has @myGroup.Members.Count members and is ready. Submit a request for tutor approval.</p>
                            <form method="post" action="/Student/RequestTutorialGroupApproval">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="tutorialGroupId" value="@myGroup.Id" />
                                <div class="mb-2">
                                    <textarea name="message" class="form-control form-control-sm" rows="2" placeholder="Optional message to tutor"></textarea>
                                </div>
                                <button class="btn btn-koi btn-sm"><i class="bi bi-send me-1"></i>Request Approval</button>
                            </form>
                        </div>
                    </div>
                }
                @if (myGroup.Status == SPMS.Models.TutorialGroupStatus.Ready && !isLeader)
                {
                    <div class="alert alert-light border small text-muted">
                        <i class="bi bi-info-circle me-2"></i>Your group is ready (@myGroup.Members.Count members). Waiting for the group leader to submit the approval request.
                    </div>
                }

                <!-- ── Awaiting Approval ── -->
                @if (myGroup.Status == SPMS.Models.TutorialGroupStatus.AwaitingApproval)
                {
                    <div class="alert alert-warning border-0">
                        <i class="bi bi-clock-history me-2"></i>
                        Approval request submitted on <strong>@latestGroupReq?.RequestedAt.ToString("dd MMM yyyy")</strong>. Waiting for your tutor to respond.
                    </div>
                }

                <!-- ── Rejected: show feedback + re-request ── -->
                @if (myGroup.Status == SPMS.Models.TutorialGroupStatus.Rejected)
                {
                    <div class="alert alert-danger border-0 mb-3">
                        <i class="bi bi-x-circle me-2"></i>
                        <strong>Group Rejected.</strong>
                        @if (!string.IsNullOrEmpty(latestGroupReq?.TutorFeedback))
                        {
                            <div class="mt-1 small">Tutor feedback: @latestGroupReq.TutorFeedback</div>
                        }
                    </div>
                    @if (isLeader)
                    {
                        <div class="card border-0 shadow-sm mb-4">
                            <div class="card-header koi-card-header py-3"><i class="bi bi-arrow-repeat me-2"></i>Re-Request Approval</div>
                            <div class="card-body p-3">
                                <form method="post" action="/Student/ReRequestTutorialGroupApproval">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="tutorialGroupId" value="@myGroup.Id" />
                                    <div class="mb-2">
                                        <textarea name="message" class="form-control form-control-sm" rows="2" placeholder="Address tutor's feedback..."></textarea>
                                    </div>
                                    <button class="btn btn-koi btn-sm"><i class="bi bi-send me-1"></i>Re-Submit Request</button>
                                </form>
                            </div>
                        </div>
                    }
                }

                <!-- ── Approved: project selection ── -->
                @if (myGroup.Status == SPMS.Models.TutorialGroupStatus.Approved)
                {
                    <div class="alert alert-success border-0 mb-3">
                        <i class="bi bi-check-circle-fill me-2"></i>
                        <strong>Group Approved!</strong>
                        @if (!string.IsNullOrEmpty(latestGroupReq?.TutorFeedback))
                        {
                            <span class="small ms-2">Tutor: @latestGroupReq.TutorFeedback</span>
                        }
                    </div>

                    @if (myGroup.ApprovedProject != null)
                    {
                        <!-- Project approved -->
                        <div class="card border-0 shadow-sm border-success border-2">
                            <div class="card-header py-3" style="background:#e8f5e9;">
                                <span class="fw-semibold text-success"><i class="bi bi-check-circle-fill me-2"></i>Project Approved</span>
                            </div>
                            <div class="card-body p-3">
                                <div class="fw-semibold mb-1">@myGroup.ApprovedProject.Title</div>
                                <div class="small text-muted">@myGroup.ApprovedProject.Description</div>
                                @if (myGroup.ApprovedProject.Company != null)
                                {
                                    <div class="small text-muted mt-1"><i class="bi bi-building me-1"></i>@myGroup.ApprovedProject.Company.CompanyName</div>
                                }
                                <a href="/Student/TutorialWeeklyProgress/@myGroup.Id" class="btn btn-koi btn-sm mt-3 w-100">
                                    <i class="bi bi-calendar-week me-1"></i>Weekly Progress
                                </a>
                            </div>
                        </div>
                    }
                    else if (latestProjReq != null && latestProjReq.Status == SPMS.Models.TutorGroupRequestStatus.Pending)
                    {
                        <!-- Project request pending -->
                        <div class="alert alert-info border-0">
                            <i class="bi bi-clock-history me-2"></i>
                            Project request pending: <strong>@latestProjReq.Project?.Title</strong><br/>
                            <small class="text-muted">Submitted @latestProjReq.RequestedAt.ToString("dd MMM yyyy"). Waiting for tutor.</small>
                        </div>
                    }
                    else
                    {
                        <!-- Show rejected feedback or initial project select -->
                        @if (latestProjReq?.Status == SPMS.Models.TutorGroupRequestStatus.Rejected)
                        {
                            <div class="alert alert-danger border-0 mb-3">
                                <i class="bi bi-x-circle me-2"></i>
                                <strong>Project request rejected.</strong>
                                @if (!string.IsNullOrEmpty(latestProjReq.TutorFeedback))
                                {
                                    <div class="small mt-1">Tutor: @latestProjReq.TutorFeedback</div>
                                }
                            </div>
                        }

                        @if (isLeader)
                        {
                            <div class="card border-0 shadow-sm">
                                <div class="card-header koi-card-header py-3"><i class="bi bi-folder2-open me-2"></i>Select a Project</div>
                                <div class="card-body p-3">
                                    <p class="small text-muted mb-3">Select one project and request tutor approval. Only Admin-approved projects are shown.</p>
                                    @if (!projects.Any())
                                    {
                                        <p class="text-muted small">No available projects at this time.</p>
                                    }
                                    else
                                    {
                                        <form method="post" action="/Student/RequestTutorialProjectApproval">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="tutorialGroupId" value="@myGroup.Id" />
                                            <div class="mb-3" style="max-height:300px;overflow-y:auto;">
                                                @foreach (var p in projects)
                                                {
                                                    <div class="form-check border rounded p-3 mb-2">
                                                        <input class="form-check-input" type="radio" name="projectId" value="@p.Id" id="proj_@p.Id" required />
                                                        <label class="form-check-label w-100" for="proj_@p.Id">
                                                            <div class="fw-semibold small">@p.Title
                                                                @if (p.Category.HasValue)
                                                                {
                                                                    <span class="badge bg-light text-dark border ms-1" style="font-size:.65rem;">@p.Category</span>
                                                                }
                                                            </div>
                                                            <div class="small text-muted">@p.Company?.CompanyName</div>
                                                            <div class="small text-muted text-truncate" style="max-width:400px;">@p.Description</div>
                                                        </label>
                                                    </div>
                                                }
                                            </div>
                                            <div class="mb-2">
                                                <textarea name="message" class="form-control form-control-sm" rows="2" placeholder="Optional message to tutor"></textarea>
                                            </div>
                                            <button class="btn btn-koi btn-sm"><i class="bi bi-send me-1"></i>Request Project Approval</button>
                                        </form>
                                    }
                                </div>
                            </div>
                        }
                        else
                        {
                            <div class="alert alert-light border small text-muted">
                                <i class="bi bi-info-circle me-2"></i>Waiting for your group leader to select a project.
                            </div>
                        }
                    }
                }
            }
        </div>

        <!-- Right: Announcements + Peers -->
        <div class="col-lg-4">
            <!-- Announcements -->
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header koi-card-header py-3"><i class="bi bi-megaphone me-2"></i>Announcements</div>
                <div class="card-body p-3" style="max-height:300px;overflow-y:auto;">
                    @if (!tutorial.Announcements.Any())
                    { <div class="text-muted small text-center py-3">No announcements yet.</div> }
                    @foreach (var a in tutorial.Announcements.OrderByDescending(x => x.PostedAt))
                    {
                        <div class="mb-3 pb-3 border-bottom">
                            <div class="d-flex justify-content-between">
                                <div class="fw-semibold small">@a.Title</div>
                                <small class="text-muted">@a.PostedAt.ToString("dd MMM")</small>
                            </div>
                            <div class="small text-muted mt-1">@a.Body</div>
                        </div>
                    }
                </div>
            </div>

            <!-- Tutorial Peers -->
            @if (peers.Any())
            {
                <div class="card border-0 shadow-sm">
                    <div class="card-header koi-card-header py-3"><i class="bi bi-person-lines-fill me-2"></i>Tutorial Peers <span class="badge bg-secondary ms-1">@peers.Count</span></div>
                    <div class="card-body p-3" style="max-height:300px;overflow-y:auto;">
                        <ul class="list-group list-group-flush">
                            @foreach (var peer in peers.Where(p => p.Student != null).OrderBy(p => p.Student!.FullName))
                            {
                                <li class="list-group-item px-0 py-2 d-flex align-items-center gap-2">
                                    <div class="rounded-circle bg-light text-dark border d-flex align-items-center justify-content-center fw-bold flex-shrink-0" style="width:30px;height:30px;font-size:.8rem;">@(peer.Student!.FullName?.FirstOrDefault() ?? '?')</div>
                                    <div>
                                        <div class="small fw-medium">@peer.Student!.FullName</div>
                                        <div style="font-size:.7rem" class="text-muted">@peer.Student.StudentNumber</div>
                                    </div>
                                </li>
                            }
                        </ul>
                    </div>
                </div>
            }
        </div>

    </div>
}

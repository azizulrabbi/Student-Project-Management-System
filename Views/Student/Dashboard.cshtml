@{ ViewData["Title"] = "Student Dashboard"; }
<div class="d-flex justify-content-between align-items-center mb-4">
    <div><h4 class="fw-bold mb-0">My Dashboard</h4><small class="text-muted">Welcome, @ViewBag.UserName</small></div>
    <a href="/Student/MyTutorial" class="btn btn-koi"><i class="bi bi-journal-bookmark me-1"></i>My Tutorial</a>
</div>
<div class="row g-3 mb-4">
    <div class="col-6 col-md-3">
        <div class="card stat-card border-0 shadow-sm h-100">
            <div class="card-body text-center py-4">
                <div class="stat-icon mb-2"><i class="bi bi-folder-check"></i></div>
                @if (ViewBag.HasApprovedProject == true)
                {
                    <div class="fw-bold mb-0 fs-6 text-success"><i class="bi bi-check-circle-fill me-1"></i>Approved</div>
                    <small class="text-muted">@ViewBag.ApprovedProjectTitle</small>
                }
                else
                {
                    <h2 class="fw-bold mb-0 text-muted">—</h2>
                    <small class="text-muted">No Project Yet</small>
                }
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card stat-card border-0 shadow-sm h-100">
            <div class="card-body text-center py-4">
                <div class="stat-icon mb-2"><i class="bi bi-people"></i></div>
                <h2 class="fw-bold mb-0">@ViewBag.MemberCount</h2>
                <small class="text-muted">Group Members</small>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card stat-card border-0 shadow-sm h-100">
            <div class="card-body text-center py-4">
                <div class="stat-icon mb-2"><i class="bi bi-chat-square-text"></i></div>
                <h2 class="fw-bold mb-0">@ViewBag.UnreadMessages</h2>
                <small class="text-muted">Unread Messages</small>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card stat-card border-0 shadow-sm h-100">
            <div class="card-body text-center py-4">
                <div class="stat-icon mb-2"><i class="bi bi-calendar-week"></i></div>
                <h2 class="fw-bold mb-0">@ViewBag.ProgressCount</h2>
                <small class="text-muted">Progress Weeks</small>
            </div>
        </div>
    </div>
</div>

<div class="row g-3">
    <div class="col-12">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header koi-card-header py-3"><i class="bi bi-lightning me-2"></i>Quick Actions</div>
            <div class="card-body p-4">
                <div class="d-flex flex-column gap-2">
                    <a href="/Student/MyTutorial" class="btn btn-outline-primary w-100 text-start">
                        <i class="bi bi-people me-2"></i>My Group &amp; Tutorial
                    </a>
                    <a href="/Student/BrowseProjects" class="btn btn-outline-secondary w-100 text-start">
                        <i class="bi bi-search me-2"></i>Browse Projects
                    </a>
                    <a href="/Message/Index" class="btn btn-outline-secondary w-100 text-start">
                        <i class="bi bi-chat-dots me-2"></i>Messages
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

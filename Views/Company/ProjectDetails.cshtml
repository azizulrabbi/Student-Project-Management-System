@model SPMS.Models.Project
@{ ViewData["Title"] = "Project Details"; }
<div class="d-flex align-items-center gap-3 mb-4">
    <a href="/Company/MyProjects" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left"></i></a>
    <h4 class="fw-bold mb-0">@Model.Title</h4>
    @{
        var b = Model.Status switch {
            ProjectStatus.PendingAdminReview => "bg-warning text-dark",
            ProjectStatus.AdminApproved => "bg-success",
            ProjectStatus.AdminRejected => "bg-danger",
            ProjectStatus.TutorReviewPending => "bg-info",
            ProjectStatus.TutorApproved => "bg-primary",
            _ => "bg-secondary"
        };
    }
    <span class="badge @b fs-6">@Model.Status</span>
    @if (Model.Status == ProjectStatus.PendingAdminReview)
    {
        <a href="/Company/EditProject/@Model.Id" class="btn btn-warning btn-sm ms-auto"><i class="bi bi-pencil-square me-1"></i>Edit Project</a>
    }
</div>
<div class="row g-4">
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm mb-3">
            <div class="card-header koi-card-header py-3"><i class="bi bi-file-text me-2"></i>Project Description</div>
            <div class="card-body p-4">
                <div class="bg-light rounded p-3" style="white-space:pre-wrap;line-height:1.7">@Model.Description</div>
                @if (!string.IsNullOrEmpty(Model.AdminNotes))
                {
                    <div class="alert alert-info mt-3 mb-0 small"><strong>Admin Notes:</strong> @Model.AdminNotes</div>
                }
                @if (Model.FilePath != null)
                {
                    <a href="/@Model.FilePath" target="_blank" class="btn btn-outline-secondary btn-sm mt-3"><i class="bi bi-file-earmark-arrow-down me-1"></i>Download Attachment</a>
                }
            </div>
        </div>
        @if (ViewBag.AssignedTutor is SPMS.Models.User tutor)
        {
            <div class="card border-0 shadow-sm border-start border-4 border-success mb-3">
                <div class="card-body p-4">
                    <h6 class="fw-bold mb-3 text-success"><i class="bi bi-person-badge me-2"></i>Assigned Tutor</h6>
                    <div class="p-2 bg-light rounded small">
                        <div class="fw-semibold"><i class="bi bi-person-badge me-1"></i>@tutor.FullName</div>
                        <div class="text-muted"><i class="bi bi-envelope me-1"></i>@tutor.Email</div>
                    </div>
                </div>
            </div>
        }
        @if (ViewBag.AssignedGroup is SPMS.Models.TutorialGroup grp && grp.Members.Any())
        {
            <div class="card border-0 shadow-sm border-start border-4 border-primary">
                <div class="card-body p-4">
                    <h6 class="fw-bold mb-3 text-primary"><i class="bi bi-people me-2"></i>Assigned Group</h6>
                    <div class="fw-semibold small mb-3">@grp.Name</div>
                    <ul class="list-unstyled mb-0">
                        @foreach (var member in grp.Members.OrderByDescending(m => m.IsLeader))
                        {
                            <li class="py-3 border-bottom">
                                <div class="d-flex align-items-center gap-2 mb-1">
                                    <i class="bi bi-person-circle fs-5 text-muted"></i>
                                    <span class="fw-semibold">@member.Student?.FullName</span>
                                    @if (member.IsLeader)
                                    {
                                        <span class="badge bg-primary ms-1" style="font-size:0.7rem">Leader</span>
                                    }
                                </div>
                                <div class="ms-4 small text-muted">
                                    @if (!string.IsNullOrEmpty(member.Student?.Email))
                                    {
                                        <div><i class="bi bi-envelope me-1"></i>@member.Student.Email</div>
                                    }
                                    @if (!string.IsNullOrEmpty(member.Student?.StudentNumber))
                                    {
                                        <div><i class="bi bi-card-text me-1"></i>Student No: @member.Student.StudentNumber</div>
                                    }
                                    @if (!string.IsNullOrEmpty(member.Student?.Program))
                                    {
                                        <div><i class="bi bi-mortarboard me-1"></i>@member.Student.Program@(member.Student.Semester != null ? $" — Semester {member.Student.Semester}" : "")</div>
                                    }
                                </div>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        }
    </div>
    <div class="col-lg-4">
        <div class="card border-0 shadow-sm mb-3">
            <div class="card-body p-4">
                <h6 class="fw-bold mb-3 text-koi-blue">Project Info</h6>
                <dl class="row small mb-0">
                    <dt class="col-5 text-muted">Category</dt><dd class="col-7">@(Model.Category?.ToString() ?? "—")</dd>
                    <dt class="col-5 text-muted">Submitted</dt><dd class="col-7">@Model.CreatedAt.ToString("dd MMM yyyy")</dd>
                    <dt class="col-5 text-muted">Last Updated</dt><dd class="col-7">@Model.UpdatedAt.ToString("dd MMM yyyy")</dd>
                    <dt class="col-5 text-muted">Students Selected</dt><dd class="col-7">@Model.StudentSelections.Count</dd>
                </dl>
            </div>
        </div>
    </div>
</div>

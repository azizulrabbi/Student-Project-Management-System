@model List<SPMS.Models.Project>
@{ ViewData["Title"] = "Manage Projects"; }
<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0">Manage Projects</h4>
    @if ((int)ViewBag.PendingCount > 0)
    {
        <span class="badge bg-warning text-dark fs-6"><i class="bi bi-clock me-1"></i>@ViewBag.PendingCount pending review</span>
    }
</div>
<div class="d-flex gap-2 flex-wrap mb-4">
    <a href="/Admin/ManageProjects" class="btn @(ViewBag.CurrentStatus == null ? "btn-koi" : "btn-outline-secondary") btn-sm">All</a>
    <a href="/Admin/ManageProjects?status=PendingAdminReview" class="btn @(ViewBag.CurrentStatus == "PendingAdminReview" ? "btn-warning" : "btn-outline-warning") btn-sm">Pending Review</a>
    <a href="/Admin/ManageProjects?status=AdminApproved" class="btn @(ViewBag.CurrentStatus == "AdminApproved" ? "btn-success" : "btn-outline-success") btn-sm">Approved</a>
    <a href="/Admin/ManageProjects?status=AdminRejected" class="btn @(ViewBag.CurrentStatus == "AdminRejected" ? "btn-danger" : "btn-outline-danger") btn-sm">Rejected</a>
    <a href="/Admin/ManageProjects?status=TutorReviewPending" class="btn @(ViewBag.CurrentStatus == "TutorReviewPending" ? "btn-info" : "btn-outline-info") btn-sm">Tutor Review</a>
    <a href="/Admin/ManageProjects?status=TutorApproved" class="btn @(ViewBag.CurrentStatus == "TutorApproved" ? "btn-primary" : "btn-outline-primary") btn-sm">Active</a>
</div>
<div class="card border-0 shadow-sm"><div class="card-body p-0"><div class="table-responsive">
    <table class="table table-hover align-middle mb-0">
        <thead><tr><th>Title</th><th>Company</th><th>Status</th><th>Category</th><th>Group</th><th>Submitted</th><th class="text-end">Actions</th></tr></thead>
        <tbody>
        @if (!Model.Any())
        {
            <tr><td colspan="7" class="text-center text-muted py-4">No projects found.</td></tr>
        }
        @foreach (var p in Model)
        {
            var b = p.Status switch {
                ProjectStatus.PendingAdminReview => "bg-warning text-dark",
                ProjectStatus.AdminApproved => "bg-success",
                ProjectStatus.AdminRejected => "bg-danger",
                ProjectStatus.TutorReviewPending => "bg-info",
                ProjectStatus.TutorApproved => "bg-primary",
                _ => "bg-secondary"
            };
            <tr>
                <td class="fw-medium">@p.Title</td>
                <td class="small">@(p.Company?.CompanyName ?? p.Company?.FullName)</td>
                <td><span class="badge @b">@p.Status</span></td>
                <td class="small">@(p.Category?.ToString() ?? "—")</td>
                <td class="small">@(p.Status == ProjectStatus.TutorApproved ? "Assigned" : "—")</td>
                <td class="small text-muted">@p.CreatedAt.ToString("dd MMM yyyy")</td>
                <td class="text-end">
                    <div class="d-flex justify-content-end gap-1">
                        <a href="/Admin/ReviewProject/@p.Id" class="btn btn-sm btn-outline-primary" title="Review"><i class="bi bi-eye"></i></a>
                        @if (p.Status == ProjectStatus.AdminApproved && !p.StudentSelections.Any())
                        {
                            <a href="/Admin/EditProject/@p.Id" class="btn btn-sm btn-outline-secondary" title="Edit"><i class="bi bi-pencil"></i></a>
                        }
                    </div>
                </td>
            </tr>
        }
        </tbody>
    </table>
</div></div></div>

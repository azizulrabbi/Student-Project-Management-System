@model SPMS.Models.Project
@{ ViewData["Title"] = "Review Project"; }
<div class="d-flex align-items-center gap-3 mb-4">
    <a href="/Admin/ManageProjects" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left"></i></a>
    <h4 class="fw-bold mb-0">Review Project</h4>
    @{
        var b = Model.Status switch {
            ProjectStatus.PendingAdminReview => "bg-warning text-dark",
            ProjectStatus.AdminApproved => "bg-success",
            ProjectStatus.AdminRejected => "bg-danger",
            _ => "bg-secondary"
        };
    }
    <span class="badge @b fs-6">@Model.Status</span>
</div>
<div class="row g-4">
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm mb-3">
            <div class="card-header koi-card-header py-3"><i class="bi bi-file-text me-2"></i>@Model.Title</div>
            <div class="card-body p-4">
                <h6 class="fw-semibold text-muted mb-2">Description</h6>
                <div class="bg-light rounded p-3 mb-4" style="white-space:pre-wrap;line-height:1.7">@Model.Description</div>
                <div class="row g-3">
                    <div class="col-sm-6">
                        <div class="small text-muted">Company</div>
                        <div class="fw-semibold">@(Model.Company?.CompanyName ?? Model.Company?.FullName)</div>
                        <div class="small text-muted">@Model.Company?.Email</div>
                    </div>
                    <div class="col-sm-6">
                        <div class="small text-muted">Submitted</div>
                        <div class="fw-semibold">@Model.CreatedAt.ToString("dd MMMM yyyy")</div>
                    </div>
                    <div class="col-sm-6">
                        <div class="small text-muted">Category</div>
                        <div>@(Model.Category?.ToString() ?? "Not set")</div>
                    </div>
                    <div class="col-sm-6">
                        <div class="small text-muted">Students Selected</div>
                        <div>@Model.StudentSelections.Count</div>
                    </div>
                </div>
                @if (Model.FilePath != null)
                {
                    <div class="mt-3">
                        <a href="/@Model.FilePath" target="_blank" class="btn btn-outline-secondary btn-sm"><i class="bi bi-file-earmark-arrow-down me-1"></i>Download Attachment</a>
                    </div>
                }
            </div>
        </div>
    </div>
    <div class="col-lg-4">
        @if (Model.Status == ProjectStatus.PendingAdminReview)
        {
            <div class="card border-0 shadow-sm mb-3">
                <div class="card-header koi-card-header py-3"><i class="bi bi-clipboard-check me-2"></i>Admin Decision</div>
                <div class="card-body p-4">
                    <div class="mb-3">
                        <label class="form-label fw-medium">Category</label>
                        <select id="catSelect" class="form-select">
                            <option value="">-- Select Category --</option>
                            <option value="Internal">Internal</option>
                            <option value="External">External</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-medium">Admin Notes</label>
                        <textarea id="notesInput" class="form-control" rows="3" placeholder="Optional notes to company..."></textarea>
                    </div>
                    <form action="/Admin/ApproveProject" method="post" class="mb-2">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="projectId" value="@Model.Id" />
                        <input type="hidden" name="category" id="catApprove" />
                        <input type="hidden" name="adminNotes" id="notesApprove" />
                        <button type="submit" class="btn btn-success w-100"
                                onclick="document.getElementById('catApprove').value=document.getElementById('catSelect').value; document.getElementById('notesApprove').value=document.getElementById('notesInput').value; return confirm('Approve this project?')">
                            <i class="bi bi-check-circle me-1"></i>Approve & Publish
                        </button>
                    </form>
                    <form action="/Admin/RejectProject" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="projectId" value="@Model.Id" />
                        <input type="hidden" name="adminNotes" id="notesReject" />
                        <button type="submit" class="btn btn-outline-danger w-100"
                                onclick="document.getElementById('notesReject').value=document.getElementById('notesInput').value; return confirm('Reject this project?')">
                            <i class="bi bi-x-circle me-1"></i>Reject
                        </button>
                    </form>
                </div>
            </div>
        }
        else
        {
            <div class="card border-0 shadow-sm border-start border-4 @(Model.Status == ProjectStatus.AdminApproved ? "border-success" : "border-danger")">
                <div class="card-body p-4">
                    <h6 class="fw-semibold mb-2">Decision Made</h6>
                    <p class="text-muted small mb-0">This project has been <strong>@Model.Status.ToString()</strong>.</p>
                    @if (!string.IsNullOrEmpty(Model.AdminNotes))
                    {<div class="mt-2 small"><strong>Notes:</strong> @Model.AdminNotes</div>}
                </div>
            </div>
        }
    </div>
</div>

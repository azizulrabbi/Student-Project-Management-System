@model SPMS.Models.Tutorial
@{ ViewData["Title"] = "Tutorial Details"; }

<div class="d-flex align-items-center gap-3 mb-4">
    <a href="/Admin/Tutorials" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left"></i></a>
    <div>
        <h4 class="fw-bold mb-0">@Model.Name</h4>
        <small class="text-muted">
            <i class="bi bi-person-badge me-1"></i>@Model.Tutor?.FullName
            &nbsp;&middot;&nbsp;
            <i class="bi bi-envelope me-1"></i>@Model.Tutor?.Email
        </small>
    </div>
</div>

@if (TempData["Success"] != null) { <div class="alert alert-success alert-dismissible fade show"><i class="bi bi-check-circle me-2"></i>@TempData["Success"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div> }

<div class="row g-4">
    <!-- Left: Enrolled Students -->
    <div class="col-lg-7">
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header koi-card-header py-3 d-flex justify-content-between align-items-center">
                <span><i class="bi bi-people me-2"></i>Enrolled Students <span class="badge bg-secondary ms-1">@Model.Enrollments.Count</span></span>
            </div>
            <div class="card-body p-3">
                @if (((List<SPMS.Models.User>)ViewBag.AvailableStudents).Any())
                {
                    <form method="post" action="/Admin/EnrollStudent" class="d-flex gap-2 mb-3">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="tutorialId" value="@Model.Id" />
                        <select name="studentId" class="form-select form-select-sm">
                            <option value="">-- Enroll a student --</option>
                            @foreach (var s in (List<SPMS.Models.User>)ViewBag.AvailableStudents)
                            {
                                <option value="@s.Id">@s.FullName (@s.StudentNumber ?? s.Email)</option>
                            }
                        </select>
                        <button class="btn btn-koi btn-sm px-3"><i class="bi bi-person-plus"></i></button>
                    </form>
                }

                @if (!Model.Enrollments.Any())
                {
                    <p class="text-muted small text-center py-3">No students enrolled yet.</p>
                }
                else
                {
                    <ul class="list-group list-group-flush">
                        @foreach (var e in Model.Enrollments.OrderBy(e => e.Student!.FullName))
                        {
                            <li class="list-group-item px-0 py-2 d-flex align-items-center gap-2">
                                <div class="rounded-circle bg-secondary text-white d-flex align-items-center justify-content-center fw-bold flex-shrink-0" style="width:34px;height:34px;">@e.Student!.FullName[0]</div>
                                <div class="flex-grow-1">
                                    <div class="small fw-medium">@e.Student.FullName</div>
                                    <div style="font-size:.72rem" class="text-muted"><i class="bi bi-envelope me-1"></i>@e.Student.Email</div>
                                    @if (e.Student.StudentNumber != null)
                                    {
                                        <div style="font-size:.72rem" class="text-muted"><i class="bi bi-hash me-1"></i>@e.Student.StudentNumber &middot; @e.Student.Program</div>
                                    }
                                </div>
                                <form method="post" action="/Admin/UnenrollStudent" onsubmit="return confirm('Remove this student?')">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="tutorialId" value="@Model.Id" />
                                    <input type="hidden" name="enrollmentId" value="@e.Id" />
                                    <button class="btn btn-sm btn-outline-danger py-0"><i class="bi bi-person-dash"></i></button>
                                </form>
                            </li>
                        }
                    </ul>
                }
            </div>
        </div>

        <!-- Groups Overview (read-only) -->
        @if (Model.Groups.Any())
        {
            <div class="card border-0 shadow-sm">
                <div class="card-header koi-card-header py-3">
                    <i class="bi bi-collection me-2"></i>Student Groups (read-only)
                </div>
                <div class="card-body p-3">
                    @foreach (var g in Model.Groups.OrderBy(g => g.Name))
                    {
                        var badgeClass = g.Status switch {
                            SPMS.Models.TutorialGroupStatus.Forming          => "bg-secondary",
                            SPMS.Models.TutorialGroupStatus.Ready            => "bg-primary",
                            SPMS.Models.TutorialGroupStatus.AwaitingApproval => "bg-warning text-dark",
                            SPMS.Models.TutorialGroupStatus.Approved         => "bg-success",
                            SPMS.Models.TutorialGroupStatus.Rejected         => "bg-danger",
                            _                                                => "bg-secondary"
                        };
                        <div class="mb-3 pb-3 border-bottom">
                            <div class="d-flex justify-content-between align-items-center mb-1">
                                <span class="fw-semibold small"><i class="bi bi-people me-1"></i>@g.Name</span>
                                <span class="badge @badgeClass">@g.Status</span>
                            </div>
                            <div class="small text-muted mb-1">@g.Members.Count member(s)</div>
                            @if (g.ApprovedProject != null)
                            {
                                <div class="small text-success"><i class="bi bi-check-circle me-1"></i>Project: @g.ApprovedProject.Title</div>
                            }
                            <div class="d-flex flex-wrap gap-1 mt-1">
                                @foreach (var m in g.Members)
                                {
                                    <span class="badge bg-light text-dark border">
                                        @m.Student?.FullName
                                        @if (m.IsLeader) { <i class="bi bi-star-fill text-warning ms-1"></i> }
                                    </span>
                                }
                            </div>
                        </div>
                    }
                </div>
            </div>
        }
    </div>

    <!-- Right: Announcements -->
    <div class="col-lg-5">
        <div class="card border-0 shadow-sm">
            <div class="card-header koi-card-header py-3"><i class="bi bi-megaphone me-2"></i>Announcements</div>
            <div class="card-body p-3" style="max-height:500px;overflow-y:auto;">
                @if (!Model.Announcements.Any())
                { <p class="text-muted small">No announcements yet. The tutor can post from their dashboard.</p> }
                else
                {
                    @foreach (var a in Model.Announcements.OrderByDescending(x => x.PostedAt))
                    {
                        <div class="mb-3 pb-3 border-bottom">
                            <div class="fw-semibold small">@a.Title</div>
                            <div class="small text-muted">@a.Body</div>
                            <div style="font-size:.7rem" class="text-muted mt-1">@a.PostedAt.ToString("dd MMM yyyy HH:mm")</div>
                        </div>
                    }
                }
            </div>
        </div>
    </div>
</div>

@model List<SPMS.Models.Tutorial>
@{ ViewData["Title"] = "Tutorials"; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0">Tutorials</h4>
    <a href="/Admin/CreateTutorial" class="btn btn-koi"><i class="bi bi-plus-circle me-1"></i>Create Tutorial</a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

@if (!Model.Any())
{
    <div class="card border-0 shadow-sm">
        <div class="card-body text-center py-5 text-muted">
            <i class="bi bi-journal-bookmark display-4 opacity-25 d-block mb-3"></i>
            <p>No tutorials yet. Create one to get started.</p>
        </div>
    </div>
}
else
{
    <div class="row g-3">
        @foreach (var t in Model)
        {
            var studentCount = t.Enrollments.Count;
            var groupCount   = t.Groups.Count;
            <div class="col-md-6 col-lg-4">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-header koi-card-header py-3">
                        <span class="fw-semibold"><i class="bi bi-journal-bookmark me-2"></i>@t.Name</span>
                    </div>
                    <div class="card-body p-3">
                        <div class="small text-muted mb-1"><i class="bi bi-person-badge me-1"></i>@t.Tutor?.FullName</div>
                        <div class="small text-muted mb-1"><i class="bi bi-envelope me-1"></i>@t.Tutor?.Email</div>
                        <div class="small text-muted mb-1"><i class="bi bi-people me-1"></i>@studentCount student(s) enrolled</div>
                        <div class="small text-muted mb-3"><i class="bi bi-collection me-1"></i>@groupCount student group(s)</div>
                        <div class="d-flex gap-2">
                            <a href="/Admin/TutorialDetails/@t.Id" class="btn btn-sm btn-outline-primary flex-grow-1">Manage</a>
                            <form method="post" action="/Admin/DeleteTutorial" onsubmit="return confirm('Delete this tutorial?')">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@t.Id" />
                                <button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}

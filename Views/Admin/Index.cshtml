@{ ViewData["Title"] = "Admin Dashboard"; }
<div class="d-flex justify-content-between align-items-center mb-4">
    <div><h4 class="fw-bold mb-0">Admin Dashboard</h4><small class="text-muted">Welcome, @ViewBag.UserName</small></div>
    <span class="badge bg-danger px-3 py-2">Administrator</span>
</div>
<div class="row g-3 mb-4">
    <div class="col-6 col-md-2">
        <div class="card stat-card border-0 shadow-sm h-100">
            <div class="card-body text-center py-4">
                <div class="stat-icon mb-2"><i class="bi bi-clock-fill"></i></div>
                <h2 class="fw-bold mb-0">@ViewBag.PendingReview</h2><small class="text-muted">Awaiting Review</small>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-2">
        <div class="card stat-card border-0 shadow-sm h-100">
            <div class="card-body text-center py-4">
                <div class="stat-icon mb-2"><i class="bi bi-check-circle-fill"></i></div>
                <h2 class="fw-bold mb-0">@ViewBag.ApprovedProjects</h2><small class="text-muted">Published Projects</small>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-2">
        <div class="card stat-card border-0 shadow-sm h-100">
            <div class="card-body text-center py-4">
                <div class="stat-icon mb-2"><i class="bi bi-people-fill"></i></div>
                <h2 class="fw-bold mb-0">@ViewBag.ActiveGroups</h2><small class="text-muted">Active Groups</small>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-2">
        <div class="card stat-card border-0 shadow-sm h-100">
            <div class="card-body text-center py-4">
                <div class="stat-icon mb-2"><i class="bi bi-journal-bookmark-fill"></i></div>
                <h2 class="fw-bold mb-0">@ViewBag.TotalTutorials</h2><small class="text-muted">Tutorials</small>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-2">
        <div class="card stat-card border-0 shadow-sm h-100">
            <div class="card-body text-center py-4">
                <div class="stat-icon mb-2"><i class="bi bi-mortarboard-fill"></i></div>
                <h2 class="fw-bold mb-0">@ViewBag.TotalStudents</h2><small class="text-muted">Students</small>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-2">
        <div class="card stat-card border-0 shadow-sm h-100">
            <div class="card-body text-center py-4">
                <div class="stat-icon mb-2"><i class="bi bi-building"></i></div>
                <h2 class="fw-bold mb-0">@ViewBag.TotalCompanies</h2><small class="text-muted">Companies</small>
            </div>
        </div>
    </div>
</div>
<div class="row g-3">
    <div class="col-md-3">
        <a href="/Admin/ManageUsers" class="card border-0 shadow-sm text-decoration-none h-100">
            <div class="card-body d-flex align-items-center gap-3 p-4">
                <div class="quick-action-icon"><i class="bi bi-people fs-3"></i></div>
                <div><div class="fw-semibold text-dark">Manage Users</div><small class="text-muted">Create &amp; edit users</small></div>
            </div>
        </a>
    </div>
    <div class="col-md-3">
        <a href="/Admin/ManageProjects?status=PendingAdminReview" class="card border-0 shadow-sm text-decoration-none h-100">
            <div class="card-body d-flex align-items-center gap-3 p-4">
                <div class="quick-action-icon" style="background:#f36d38"><i class="bi bi-clock fs-3"></i></div>
                <div><div class="fw-semibold text-dark">Review Projects</div><small class="text-muted">@ViewBag.PendingReview pending</small></div>
            </div>
        </a>
    </div>
    <div class="col-md-3">
        <a href="/Admin/ManageGroups" class="card border-0 shadow-sm text-decoration-none h-100">
            <div class="card-body d-flex align-items-center gap-3 p-4">
                <div class="quick-action-icon" style="background:#3CBFB8"><i class="bi bi-diagram-3 fs-3"></i></div>
                <div><div class="fw-semibold text-dark">Student Groups</div><small class="text-muted">@ViewBag.ActiveGroups active, @ViewBag.PendingGroups pending</small></div>
            </div>
        </a>
    </div>
    <div class="col-md-3">
        <a href="/Admin/Tutorials" class="card border-0 shadow-sm text-decoration-none h-100">
            <div class="card-body d-flex align-items-center gap-3 p-4">
                <div class="quick-action-icon" style="background:#5c6bc0"><i class="bi bi-journal-bookmark fs-3"></i></div>
                <div><div class="fw-semibold text-dark">Tutorials</div><small class="text-muted">@ViewBag.TotalTutorials running</small></div>
            </div>
        </a>
    </div>
</div>

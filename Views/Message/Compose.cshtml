@{ ViewData["Title"] = "Compose Message"; }

<div class="d-flex align-items-center gap-3 mb-4">
    <a href="/Message/Index" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left"></i></a>
    <h2 class="fw-bold mb-0">New Message</h2>
</div>

<div class="row">
    <div class="col-lg-6">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-bottom py-3">
                <h5 class="mb-0 fw-semibold"><i class="bi bi-pencil-square me-2 text-primary"></i>Send Message</h5>
            </div>
            <div class="card-body p-4">
                <form action="/Message/Send" method="post">
                    @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <label class="form-label fw-medium">Send To *</label>
                        <select name="ReceiverId" class="form-select" required>
                            <option value="">-- Select recipient --</option>
                            @foreach (var user in (List<SPMS.Models.User>)ViewBag.AvailableUsers)
                            {
                                var label = user.Role switch
                                {
                                    SPMS.Models.UserRole.Student => $"Student - {user.FullName}",
                                    SPMS.Models.UserRole.Tutor => $"Tutor - {user.FullName}",
                                    SPMS.Models.UserRole.Company => $"Company - {user.CompanyName ?? user.FullName}",
                                    _ => user.FullName
                                };
                                <option value="@user.Id">@label</option>
                            }
                        </select>
                    </div>
                    <div class="mb-4">
                        <label class="form-label fw-medium">Message *</label>
                        <textarea name="Content" class="form-control" rows="6" required
                                  placeholder="Write your message..."></textarea>
                    </div>
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-koi px-4">
                            <i class="bi bi-send me-1"></i>Send Message
                        </button>
                        <a href="/Message/Index" class="btn btn-outline-secondary px-4">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="col-lg-6">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-bottom py-3">
                <h5 class="mb-0 fw-semibold"><i class="bi bi-info-circle me-2 text-info"></i>Messaging Guide</h5>
            </div>
            <div class="card-body p-4">
                @{
                    var role = ViewBag.UserRole?.ToString() ?? Context.Session.GetString("UserRole") ?? "";
                }
                @if (role == "Student")
                {
                    <p class="small text-muted">As a student, you can message:</p>
                    <ul class="small text-muted">
                        <li><strong>Tutors</strong> — For project guidance and feedback</li>
                        <li><strong>Companies</strong> — For project coordination and clarifications</li>
                    </ul>
                }
                else if (role == "Tutor")
                {
                    <p class="small text-muted">As a tutor, you can message:</p>
                    <ul class="small text-muted">
                        <li><strong>Students</strong> — To provide guidance and feedback</li>
                        <li><strong>Companies</strong> — To coordinate on industry projects</li>
                    </ul>
                }
                else if (role == "Company")
                {
                    <p class="small text-muted">As a company, you can message:</p>
                    <ul class="small text-muted">
                        <li><strong>Students</strong> — To discuss project requirements</li>
                        <li><strong>Tutors</strong> — To coordinate on student projects</li>
                    </ul>
                }
            </div>
        </div>
    </div>
</div>

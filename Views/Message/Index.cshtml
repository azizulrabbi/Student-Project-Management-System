@model List<SPMS.Models.User>
@{ ViewData["Title"] = "Messages"; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold mb-0"><i class="bi bi-chat-dots me-2 text-primary"></i>Messages</h2>
    <a href="/Message/Compose" class="btn btn-koi">
        <i class="bi bi-pencil-square me-1"></i>New Message
    </a>
</div>

<div class="row">
    <!-- Conversations List -->
    <div class="col-md-5 col-lg-4">
        <div class="card border-0 shadow-sm">
            <div class="card-header koi-card-header py-3">
                <h6 class="mb-0 fw-semibold">Conversations</h6>
            </div>
            <div class="list-group list-group-flush">
                @if (!Model.Any())
                {
                    <div class="text-center text-muted py-4 px-3">
                        <i class="bi bi-chat-x display-4 opacity-25 d-block mb-2"></i>
                        <small>No conversations yet</small>
                    </div>
                }
                @foreach (var user in Model)
                {
                    var unread = ((Dictionary<int, int>)ViewBag.UnreadCounts).GetValueOrDefault(user.Id, 0);
                    <a href="/Message/Conversation/@user.Id"
                       class="list-group-item list-group-item-action d-flex align-items-center gap-3 py-3 px-3">
                        <span class="user-avatar user-avatar-sm">@user.FullName[0]</span>
                        <div class="flex-grow-1 min-width-0">
                            <div class="fw-medium text-truncate">@user.FullName</div>
                            <small class="text-muted">@user.Role</small>
                            <div style="font-size:.7rem" class="text-muted text-truncate"><i class="bi bi-envelope me-1"></i>@user.Email</div>
                        </div>
                        @if (unread > 0)
                        {
                            <span class="badge bg-danger rounded-pill">@unread</span>
                        }
                    </a>
                }
            </div>
        </div>

        <!-- Available Users to Message -->
        @if (ViewBag.AvailableUsers is List<SPMS.Models.User> available && available.Any())
        {
            <div class="card border-0 shadow-sm mt-3">
                <div class="card-header koi-card-header py-3">
                    <h6 class="mb-0 fw-semibold text-muted">Start New Conversation</h6>
                </div>
                <div class="list-group list-group-flush">
                    @foreach (var user in available.Take(8))
                    {
                        <a href="/Message/Conversation/@user.Id"
                           class="list-group-item list-group-item-action d-flex align-items-center gap-2 py-2 px-3">
                            <span class="user-avatar user-avatar-sm">@user.FullName[0]</span>
                            <div>
                                <div class="small fw-medium">@user.FullName</div>
                                <div style="font-size:.7rem" class="text-muted">@user.Role</div>
                                <div style="font-size:.7rem" class="text-muted"><i class="bi bi-envelope me-1"></i>@user.Email</div>
                            </div>
                        </a>
                    }
                </div>
            </div>
        }
    </div>

    <!-- Welcome / Select chat -->
    <div class="col-md-7 col-lg-8">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex flex-column align-items-center justify-content-center text-center py-5">
                <i class="bi bi-chat-quote display-3 text-muted opacity-25 mb-3"></i>
                <h5 class="text-muted">Select a conversation</h5>
                <p class="text-muted small">Choose a contact from the left to start chatting</p>
                <a href="/Message/Compose" class="btn btn-outline-primary mt-2">
                    <i class="bi bi-pencil-square me-1"></i>Compose New Message
                </a>
            </div>
        </div>
    </div>
</div>

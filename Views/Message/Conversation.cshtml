@model List<SPMS.Models.Message>
@{ ViewData["Title"] = "Conversation"; var otherUser = (SPMS.Models.User)ViewBag.OtherUser; int currentUserId = ViewBag.CurrentUserId; }

<div class="d-flex align-items-center gap-3 mb-3">
    <a href="/Message/Index" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left"></i></a>
    <div class="d-flex align-items-center gap-2">
        <span class="user-avatar">@otherUser.FullName[0]</span>
        <div>
            <div class="fw-semibold">@otherUser.FullName</div>
            <small class="text-muted">@otherUser.Role</small>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm" style="height:calc(100vh - 260px); display:flex; flex-direction:column">
    <!-- Messages area -->
    <div class="card-body flex-grow-1 overflow-auto p-4" id="messagesArea" style="display:flex;flex-direction:column;gap:.75rem">
        @if (!Model.Any())
        {
            <div class="text-center text-muted my-auto">
                <i class="bi bi-chat display-4 opacity-25 d-block mb-2"></i>
                <small>No messages yet. Send the first message below.</small>
            </div>
        }
        @foreach (var msg in Model)
        {
            bool isMe = msg.SenderId == currentUserId;
            <div class="d-flex @(isMe ? "justify-content-end" : "justify-content-start")">
                <div class="message-bubble @(isMe ? "message-sent" : "message-received")" style="max-width:70%">
                    <div>@msg.Content</div>
                    <div class="message-time @(isMe ? "text-end" : "")">
                        @msg.SentAt.ToString("dd MMM, HH:mm")
                        @if (isMe && msg.IsRead)
                        {
                            <i class="bi bi-check2-all text-info ms-1"></i>
                        }
                        else if (isMe)
                        {
                            <i class="bi bi-check2 ms-1"></i>
                        }
                    </div>
                </div>
            </div>
        }
    </div>

    <!-- Reply area -->
    <div class="card-footer bg-white border-top p-3">
        <form action="/Message/Send" method="post" class="d-flex gap-2">
            @Html.AntiForgeryToken()
            <input type="hidden" name="ReceiverId" value="@otherUser.Id" />
            <input type="text" name="Content" class="form-control" placeholder="Type a message..."
                   autocomplete="off" required minlength="1" />
            <button type="submit" class="btn btn-koi px-3">
                <i class="bi bi-send-fill"></i>
            </button>
        </form>
    </div>
</div>

@section Scripts {
<script>
// Scroll to bottom of messages
const area = document.getElementById('messagesArea');
area.scrollTop = area.scrollHeight;
</script>
}

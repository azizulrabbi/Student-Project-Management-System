@model List<SPMS.Models.Tutorial>
@{ ViewData["Title"] = "My Tutorials"; }

<div class="mb-4"><h4 class="fw-bold mb-0">My Tutorials</h4></div>

@if (!Model.Any())
{
    <div class="card border-0 shadow-sm">
        <div class="card-body text-center py-5 text-muted">
            <i class="bi bi-journal-bookmark display-4 opacity-25 d-block mb-3"></i>
            <p>No tutorials assigned to you yet.</p>
        </div>
    </div>
}
else
{
    <div class="row g-3">
        @foreach (var t in Model)
        {
            var studentCount    = t.Enrollments.Count;
            var groupCount      = t.Groups.Count;
            var pendingGroupReqs = t.Groups.Count(g => g.Status == SPMS.Models.TutorialGroupStatus.AwaitingApproval);
            <div class="col-md-6">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-header koi-card-header py-3">
                        <span class="fw-semibold"><i class="bi bi-journal-bookmark me-2"></i>@t.Name</span>
                    </div>
                    <div class="card-body p-3">
                        <div class="small text-muted mb-1"><i class="bi bi-people me-1"></i>@studentCount student(s) enrolled</div>
                        <div class="small text-muted mb-1"><i class="bi bi-collection me-1"></i>@groupCount group(s)</div>
                        <div class="small text-muted mb-1"><i class="bi bi-megaphone me-1"></i>@t.Announcements.Count announcement(s)</div>
                        @if (pendingGroupReqs > 0)
                        {
                            <div class="small text-warning fw-semibold mb-2"><i class="bi bi-clock-history me-1"></i>@pendingGroupReqs pending approval request(s)</div>
                        }
                        <a href="/Tutor/TutorialDetails/@t.Id" class="btn btn-koi btn-sm w-100 mt-1">Open Tutorial</a>
                    </div>
                </div>
            </div>
        }
    </div>
}

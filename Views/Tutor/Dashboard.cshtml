@{ ViewData["Title"] = "Tutor Dashboard"; }
<div class="d-flex justify-content-between align-items-center mb-4">
    <div><h4 class="fw-bold mb-0">Tutor Dashboard</h4><small class="text-muted">Welcome, @ViewBag.UserName</small></div>
    <span class="badge bg-primary px-3 py-2">Tutor</span>
</div>
<div class="row g-3 mb-4">
    <div class="col-6 col-md-3">
        <div class="card stat-card border-0 shadow-sm h-100">
            <div class="card-body text-center py-4">
                <div class="stat-icon mb-2"><i class="bi bi-clock-fill"></i></div>
                <h2 class="fw-bold mb-0">@ViewBag.PendingRequests</h2><small class="text-muted">Pending Requests</small>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card stat-card border-0 shadow-sm h-100">
            <div class="card-body text-center py-4">
                <div class="stat-icon mb-2"><i class="bi bi-people-fill"></i></div>
                <h2 class="fw-bold mb-0">@ViewBag.ActiveGroups</h2><small class="text-muted">Active Groups</small>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <a href="/Tutor/MyTutorials" class="card stat-card border-0 shadow-sm h-100 text-decoration-none @(ViewBag.AwaitingFeedback > 0 ? "border border-warning border-2" : "")">
            <div class="card-body text-center py-4">
                <div class="stat-icon mb-2"><i class="bi bi-chat-left-text"></i></div>
                <h2 class="fw-bold mb-0 @(ViewBag.AwaitingFeedback > 0 ? "text-warning" : "")">@ViewBag.AwaitingFeedback</h2>
                <small class="text-muted">Awaiting Feedback</small>
                @if (ViewBag.AwaitingFeedback > 0)
                {<div class="mt-1"><small class="text-warning fw-semibold">Click to action →</small></div>}
            </div>
        </a>
    </div>
    <div class="col-6 col-md-3">
        <div class="card stat-card border-0 shadow-sm h-100">
            <div class="card-body text-center py-4">
                <div class="stat-icon mb-2"><i class="bi bi-envelope-fill"></i></div>
                <h2 class="fw-bold mb-0">@ViewBag.UnreadMessages</h2><small class="text-muted">Unread Messages</small>
            </div>
        </div>
    </div>
</div>
<div class="row g-3">
    <div class="col-md-4">
        <a href="/Tutor/PendingRequests" class="card border-0 shadow-sm text-decoration-none h-100">
            <div class="card-body d-flex align-items-center gap-3 p-4">
                <div class="quick-action-icon" style="background:#f36d38"><i class="bi bi-clock fs-3"></i></div>
                <div><div class="fw-semibold text-dark">Pending Requests</div><small class="text-muted">@ViewBag.PendingRequests awaiting response</small></div>
            </div>
        </a>
    </div>
    <div class="col-md-4">
        <a href="/Tutor/ActiveGroups" class="card border-0 shadow-sm text-decoration-none h-100">
            <div class="card-body d-flex align-items-center gap-3 p-4">
                <div class="quick-action-icon"><i class="bi bi-people fs-3"></i></div>
                <div><div class="fw-semibold text-dark">Active Groups</div><small class="text-muted">View progress logs</small></div>
            </div>
        </a>
    </div>
    <div class="col-md-4">
        <a href="/Tutor/MyTutorials" class="card border-0 shadow-sm text-decoration-none h-100 @(ViewBag.AwaitingFeedback > 0 ? "border border-warning" : "")">
            <div class="card-body d-flex align-items-center gap-3 p-4">
                <div class="quick-action-icon" style="background:#f59e0b"><i class="bi bi-chat-left-text fs-3"></i></div>
                <div>
                    <div class="fw-semibold text-dark">Give Feedback</div>
                    <small class="text-muted">@ViewBag.AwaitingFeedback submission(s) waiting</small>
                </div>
            </div>
        </a>
    </div>
    <div class="col-md-4">
        <a href="/Message/Index" class="card border-0 shadow-sm text-decoration-none h-100">
            <div class="card-body d-flex align-items-center gap-3 p-4">
                <div class="quick-action-icon" style="background:#3CBFB8"><i class="bi bi-chat-dots fs-3"></i></div>
                <div><div class="fw-semibold text-dark">Messages</div><small class="text-muted">@ViewBag.UnreadMessages unread</small></div>
            </div>
        </a>
    </div>
</div>
